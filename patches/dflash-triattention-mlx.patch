+def _apply_triattention_step(runtime: _TriAttentionRuntime, target_cache, *, is_prefill: bool, current_position: int) -> None:
+    kv_states = [target_cache[idx].state for idx in runtime.kv_indices]
+    if not is_prefill and kv_states:
+        seq_len = int(kv_states[0][0].shape[2])
+        cache_positions = getattr(runtime.compressor, "cache_positions", [])
+        if seq_len <= 0:
+            runtime.compressor.cache_positions = []
+        elif len(cache_positions) != seq_len:
+            start_pos = max(current_position - seq_len + 1, 0)
+            runtime.compressor.cache_positions = list(range(start_pos, start_pos + seq_len))
+        runtime.compressor.absolute_position = current_position + 1
+    kv_states = runtime.step_fn(
+        runtime.compressor,
+        kv_states,
+        is_prefill=is_prefill,
+        current_position=current_position,
+    )
+    for idx, state in zip(runtime.kv_indices, kv_states):
+        target_cache[idx].state = state
+
